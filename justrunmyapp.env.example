BOT_TOKEN=
DATABASE_URL=postgresql://USER:PASSWORD@POSTGRES_HOST:5432/DATABASE
REDIS_URL=redis://REDIS_HOST:6379
NODE_ENV=production
LOG_LEVEL=info
